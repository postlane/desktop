{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Postlane",
  "version": "0.1.0",
  "identifier": "com.postlane.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Postlane",
        "width": 1100,
        "height": 700,
        "minWidth": 820,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "hardenedRuntime": true
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "PLACEHOLDER_PUBKEY_TO_BE_GENERATED_BEFORE_V0.1.0",
      "endpoints": ["https://github.com/postlane/desktop/releases/latest/download/latest.json"]
    },
    "deep-link": {
      "schemes": ["postlane"]
    }
  }
}
