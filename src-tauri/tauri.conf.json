{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Postlane",
  "version": "0.1.3",
  "identifier": "com.postlane.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "postlane",
        "width": 980,
        "height": 700,
        "minWidth": 820,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://avatars.githubusercontent.com https://secure.gravatar.com https://gitlab.com; font-src 'self' data:; connect-src 'self' http://localhost:* https://api.github.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "hardenedRuntime": true,
      "entitlements": "../Entitlements.plist",
      "signingIdentity": "Developer ID Application: Hugo Elliott (RNUCP3LV48)"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNENzBERjNEMzdCMjdFQjIKUldTeWZySTNQZDl3UFh2SEhNZ3JFMnRNbXZwWWRJQTZjcmF2cENkY0xHTkFvOFA3aWZEVUs0WmsK",
      "endpoints": ["https://github.com/postlane/desktop/releases/latest/download/latest.json"]
    },
    "deep-link": {
      "desktop": {
        "schemes": ["postlane"]
      }
    }
  }
}
